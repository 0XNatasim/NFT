# ===== App =====
NEXT_PUBLIC_APP_NAME="Handshake"

# ===== Monad chain (Mainnet) =====
NEXT_PUBLIC_CHAIN_ID=143
NEXT_PUBLIC_MONAD_RPC_URL=https://monad.rpc.blxrbdn.com
# Optional comma-separated browser/wallet RPC fallbacks. The app has built-in
# Monad mainnet fallbacks, but set this when a specific RPC is healthier.
NEXT_PUBLIC_MONAD_RPC_URLS=https://monad.rpc.blxrbdn.com,https://monad-mainnet.drpc.org,https://rpc-mainnet.monadinfra.com,https://rpc3.monad.xyz,https://rpc1.monad.xyz,https://rpc.monad.xyz
NEXT_PUBLIC_MONAD_EXPLORER_URL=https://monadscan.com

# ===== Wallet =====
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ===== Contracts =====
NEXT_PUBLIC_SETTLEMENT_CONTRACT_ADDRESS=0x017605384782b0841Fde1f1E8539EbEDD2c43420

# ===== Supabase =====
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ===== NFT indexing provider: "alchemy" | "opensea" =====
NFT_PROVIDER=alchemy
ALCHEMY_API_KEY=
# Also the collection logo/metadata source: names and logos are resolved via
# OpenSea (after the on-chain contractURI check). Set this so curated
# collections without a local logo file still get artwork.
OPENSEA_API_KEY=
# OpenSea chain slug ("monad" mainnet)
OPENSEA_CHAIN=monad

# ===== IPFS gateways for NFT media =====
# Comma-separated, first is tried first, rest are fallbacks. Public gateways
# (ipfs.io, dweb.link, nftstorage.link) can rate-limit under
# load, so IPFS-hosted collections (e.g. 10kSquad) can fail to load. If you
# have a dedicated gateway, put it first here. Server-side resolution uses
# IPFS_GATEWAYS; browser <img> fallback resolution uses NEXT_PUBLIC_IPFS_GATEWAYS.
# NOTE: gateway URLs MUST end in /ipfs/.
# IPFS_GATEWAYS=https://your-dedicated-gateway.example/ipfs/,https://ipfs.io/ipfs/
# NEXT_PUBLIC_IPFS_GATEWAYS=https://your-dedicated-gateway.example/ipfs/,https://ipfs.io/ipfs/
# ARWEAVE_GATEWAY=https://arweave.net/

# ===== Collection pricing (floor on NFT cards) =====
# Dedicated price source, independent of NFT_PROVIDER: "opensea".
# If unset, falls back to the wallet provider (when it can price), then any
# pricing-capable provider whose API key is set. OpenSea gives the floor price.
PRICE_PROVIDER=opensea

# ===== Deal Rooms (optional) =====
# Secret for the stateless room-session tokens. If unset, a key derived from
# SUPABASE_SERVICE_ROLE_KEY is used, so no extra config is required.
# ROOM_SESSION_SECRET=
# Bearer secret protecting /api/cron/deal-rooms (Vercel Cron reconciliation).
# CRON_SECRET=

# ===== Rate limiting (optional; distributed across serverless instances) =====
# Set both to enable Upstash Redis-backed rate limiting. If unset, the API
# falls back to a process-local limiter (fine for single-instance/dev).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ===== Contract deployment (server-side only, NEVER commit real values) =====
MONAD_RPC_URL=https://monad.rpc.blxrbdn.com
# Optional comma-separated server-side RPC fallbacks used for on-chain NFT
# tokenURI/name/code reads. These keep NFT art loading when one endpoint lags.
MONAD_RPC_URLS=https://monad.rpc.blxrbdn.com,https://monad-mainnet.drpc.org,https://rpc-mainnet.monadinfra.com,https://rpc3.monad.xyz,https://rpc1.monad.xyz,https://rpc.monad.xyz
PRIVATE_KEY_DEPLOYER=
FEE_RECIPIENT_ADDRESS=
CONTRACT_OWNER=
# Optional launch allowlist: comma-separated collection addresses seeded as
# tradable in the deployment block (no ADD_DELAY). Leave unset to seed none;
# every collection must then be added post-deploy via proposeCollection.
# INITIAL_COLLECTIONS=0xCollectionA,0xCollectionB

# ===== Collection allowlist watcher (scripts/watch-collections.mjs) =====
# Alerts on CollectionProposed during the 48h ADD_DELAY window so a malicious
# proposal can be removeCollection'd before it becomes tradable.
HANDSHAKE_ADDRESS=0x017605384782b0841fde1f1e8539ebedd2c43420
# Optional Slack/Discord-style webhook to page a human; console-only if unset.
# ALERT_WEBHOOK_URL=
# Optional: expected collections (defaults to the launch seed set). Anything
# proposed outside this set is alerted loudly.
# KNOWN_COLLECTIONS=0xCollectionA,0xCollectionB
