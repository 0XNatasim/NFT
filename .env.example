# ===== App =====
NEXT_PUBLIC_APP_NAME="Monad Market"

# ===== Monad chain (Mainnet) =====
NEXT_PUBLIC_CHAIN_ID=143
NEXT_PUBLIC_MONAD_RPC_URL=https://rpc.monad.xyz
NEXT_PUBLIC_MONAD_EXPLORER_URL=https://monadscan.com

# ===== Wallet =====
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ===== Contracts =====
NEXT_PUBLIC_SETTLEMENT_CONTRACT_ADDRESS=0xA9E7f8D08ecd275D9Dd7C95cF9a557B8bce4a277

# ===== Supabase =====
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ===== NFT indexing provider: "alchemy" | "reservoir" | "opensea" =====
NFT_PROVIDER=alchemy
ALCHEMY_API_KEY=
RESERVOIR_API_KEY=
SIMPLEHASH_API_KEY=
OPENSEA_API_KEY=
# OpenSea chain slug ("monad" mainnet)
OPENSEA_CHAIN=monad

# ===== Rate limiting (optional; distributed across serverless instances) =====
# Set both to enable Upstash Redis-backed rate limiting. If unset, the API
# falls back to a process-local limiter (fine for single-instance/dev).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ===== Contract deployment (server-side only, NEVER commit real values) =====
MONAD_RPC_URL=https://rpc.monad.xyz
PRIVATE_KEY_DEPLOYER=
FEE_RECIPIENT_ADDRESS=
CONTRACT_OWNER=
